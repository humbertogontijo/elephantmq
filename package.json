{
  "name": "elephantmq",
  "version": "1.0.4",
  "description": "PostgreSQL-native job queue with a familiar producer/worker API",
  "homepage": "https://github.com/humbertogontijo/elephantmq",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/humbertogontijo/elephantmq.git"
  },
  "bugs": {
    "url": "https://github.com/humbertogontijo/elephantmq/issues"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./migrate": {
      "import": {
        "types": "./dist/esm/migrate.d.ts",
        "default": "./dist/esm/migrate.js"
      },
      "require": {
        "types": "./dist/cjs/migrate.d.ts",
        "default": "./dist/cjs/migrate.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "keywords": [
    "queue",
    "jobs",
    "job-queue",
    "postgres",
    "postgresql",
    "pg",
    "background-jobs",
    "scheduler",
    "worker"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run tsc:all && npm run copy:sql && npm run write:dist:pkg && npm run clean:temp:files",
    "clean:temp:files": "rimraf dist/cjs/elephantmq.d.ts dist/esm/elephantmq.d.ts dist/tsdoc-metadata.json",
    "write:dist:pkg": "node scripts/write-dist-pkg.cjs",
    "copy:sql": "rimraf dist/cjs/sql dist/esm/sql && cpx \"./src/sql/**/*.sql\" ./dist/cjs/sql && cpx \"./src/sql/**/*.sql\" ./dist/esm/sql",
    "lint": "node scripts/lint-sql.js && eslint .",
    "pretest": "npm run build",
    "migrate:test": "node scripts/migrate-test.js",
    "sql-smoketest": "node scripts/sql-smoketest.js",
    "test": "node scripts/run-vitest.cjs",
    "test:serial": "ELEPHANTMQ_TEST_PARALLEL=0 node scripts/run-vitest.cjs",
    "test:vitest": "vitest run --testTimeout 20000 --hookTimeout 20000",
    "test:coverage": "vitest run --coverage --testTimeout 20000 --hookTimeout 20000",
    "test:watch": "vitest",
    "tsc": "tsc",
    "tsc:all": "tsc && tsc -p tsconfig-cjs.json",
    "attw": "attw --pack ."
  },
  "dependencies": {
    "cron-parser": "4.9.0",
    "pg": "^8.13.1",
    "tslib": "2.8.1",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.39.0",
    "@types/node": "24.12.2",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "4.1.2",
    "cpx2": "8.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "8.10.2",
    "eslint-plugin-prettier": "4.2.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-tsdoc": "0.5.2",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "squawk-cli": "2.47.0",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  }
}
