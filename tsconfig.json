{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2017",
    "module": "ES2020",
    "incremental": true,
    "declaration": true,
    "outDir": "dist/esm",
    "sourceMap": true,
    "inlineSources": true,
    "strict": true,
    "jsx": "preserve",
    "importHelpers": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "lib": ["esnext", "DOM"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}
